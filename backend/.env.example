# Server Config
PORT=5001
JWT_SECRET=your_jwt_secret_here # Secret for signing authentication tokens

# Blockchain Config
RPC_URL=your_sepolia_rpc_url_here # Ethereum node RPC URL
VERIFIER_PRIVATE_KEY=your_verifier_private_key_here # Private key for the verifier account
IDENTITY_CONTRACT_ADDRESS=your_identity_contract_address_here
AUCTION_CONTRACT_ADDRESS=your_auction_contract_address_here

# Database Config (MySQL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=blockchain_db
DB_PORT=3306

# Database Aliases (Sequelize often uses these)
MYSQLHOST=127.0.0.1
MYSQLUSER=root
MYSQLPASSWORD=your_db_password_here
MYSQLDATABASE=blockchain_db
MYSQLPORT=3306

# Pinata Config (IPFS Storage)
PINATA_JWT=your_pinata_jwt_here
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here
