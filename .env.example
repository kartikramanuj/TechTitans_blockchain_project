# Blockchain Deployment (Hardhat/Foundry)
# Used for contract deployment and scripts
SEPOLIA_RPC_URL=your_sepolia_rpc_url_here
PRIVATE_KEY=your_wallet_private_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_for_verification

# Frontend Config (Next.js)
# These MUST start with NEXT_PUBLIC_ to be accessible in the browser
NEXT_PUBLIC_IDENTITY_CONTRACT_ADDRESS=your_identity_contract_address_here
NEXT_PUBLIC_AUCTION_CONTRACT_ADDRESS=your_auction_contract_address_here
NEXT_PUBLIC_EXPECTED_CHAIN_ID=11155111 # 11155111 for Sepolia, 31337 for Local
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001/api
